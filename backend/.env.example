# ── API Keys ──────────────────────────────────────────────────────────────────
GNEWS_API_KEY=your_gnews_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/marketpulse

# ── GNews config ──────────────────────────────────────────────────────────────
GNEWS_POLL_INTERVAL_MINUTES=5
GNEWS_MAX_ARTICLES=10
GNEWS_LANG=en
GNEWS_COUNTRY=in

# ── Gemini config ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
FINANCE_FILTER_CONFIDENCE_THRESHOLD=0.6

# ── Redis (optional, leave blank to use in-memory queue) ──────────────────────
# REDIS_URL=redis://localhost:6379

# ── AWS Vector Store (Bedrock + OpenSearch Serverless) ────────────────────────
# Step 1: Create IAM user with infra/aws_policy.json attached
# Step 2: Run: python setup_aws.py  (creates the OpenSearch Serverless collection)
# Step 3: Paste the endpoint printed by setup_aws.py below
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
# Full HTTPS endpoint — printed by setup_aws.py once collection is ACTIVE:
OPENSEARCH_ENDPOINT=https://xxxxxxxxxxxxxx.us-east-1.aoss.amazonaws.com
