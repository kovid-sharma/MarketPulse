# ── API Keys ──────────────────────────────────────────────────────────────────
GNEWS_API_KEY=your_gnews_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
# Local example:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/marketpulse
# Render PostgreSQL example (replace with your actual Render DB URL):
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/marketpulse

# ── GNews config ──────────────────────────────────────────────────────────────
GNEWS_POLL_INTERVAL_MINUTES=5
GNEWS_MAX_ARTICLES=10
GNEWS_LANG=en
GNEWS_COUNTRY=in

# ── Gemini config ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
FINANCE_FILTER_CONFIDENCE_THRESHOLD=0.6

# ── Redis (optional, leave blank to use in-memory queue) ──────────────────────
# REDIS_URL=redis://localhost:6379
