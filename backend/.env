# ── API Keys ──────────────────────────────────────────────────────────────────
GNEWS_API_KEY=dummy_gnews_api_key
GEMINI_API_KEY=dummy_gemini_api_key

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://localhost:54320/marketpulse

# ── GNews config ──────────────────────────────────────────────────────────────
GNEWS_POLL_INTERVAL_MINUTES=5
GNEWS_MAX_ARTICLES=10
GNEWS_LANG=en
GNEWS_COUNTRY=in

# ── Gemini config ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
FINANCE_FILTER_CONFIDENCE_THRESHOLD=0.6
